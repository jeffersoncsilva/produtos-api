@page "/produtos"
@using RO.DevTest.FronEnd.Application.Features.Products.GetProductsCommand
@using RO.DevTest.FrontEnd.ViewModels.Features.Product
@inject IMediator Mediator
@inject NavigationManager NavManager

<h3>Produtos</h3>

@if (!_products?.Any() ?? false)
{
    <h4>Nenhum produto encontrado!</h4>
}
else
{
    @foreach(var product in _products ?? [])
    {
        <ProdutoComponent Product="@product" />
    }
}

<button type="button" @onclick="NavegaPaginaNovoProduto" class="btn btn-primary btn-sm m-2">
    Novo Produto
</button>

@code {
    private int page = 0;
    private int size = 5;
    private IEnumerable<ProductSimpleViewModel>? _products;

    protected override async Task OnInitializedAsync()
    {
        var resultado = await Mediator.Send(new GetProductCommandRequest(page, size));
        _products = resultado.Products;
        page = resultado.Page;
        size = resultado.Size;
    }

    private void NavegaPaginaNovoProduto()
    {
        NavManager.NavigateTo("novo-produto");
    }
}

@page "/vendas-detalhes"


@if (_carregando)
{
    <Carregando Tipo="Carregando.ECarregandoTipo.Primary" EstaCarregando="_carregando" />
}
else if (_erroAoCarregar || _response is null)
{
    <Alerta Tipo="Alerta.TipoAlerta.Erro" Mensagem="Não foi possível carregar os detalhes da venda." />
    <BotaoTentarNovamente TentarNovamente="@(async () => await CarregarVendaDetalhe())" />
}
else
{

    <h3 class="fs-3 text-center my-4">Detalhes da Venda</h3>

    <div class="col-md-8 mx-auto">

        <div class="form-group row my-2 ">
            <label class="form-label col-md-3 my-auto text-end">Observação venda:</label>
            <div class="col-md-9">
                <input type="text" class="form-control desabled" value="@_response.Observatin" disabled />
            </div>
        </div>

        <div class="form-group row my-2">
            <label class="form-label col-md-3 my-auto text-end">Quantidade de produtos:</label>
            <div class="col-md-9">
                <input type="text" class="form-control desabled" value="@_response.Itens.Count" disabled />
            </div>
        </div>

        <div class="form-group row my-2">
            <label class="form-label col-md-3 my-auto text-end">Quantidade total de itens:</label>
            <div class="col-md-9">
                <input type="text" class="form-control desabled" value="@_response.Itens.Sum(i => i.Quantity)" disabled />
            </div>
        </div>

        <div class="form-group row my-2">
            <label class="form-label col-md-3 my-auto text-end">Valor total venda:</label>
            <div class="col-md-9">
                <input type="text" class="form-control desabled" value="@_response.Price.ToString("C")" disabled />
            </div>
        </div>

        <div class="form-group row my-2">
            <label class="form-label col-md-3 my-auto text-end">Desconto:</label>
            <div class="col-md-9">
                <input type="text" class="form-control desabled" value="@_response.Descount.ToString("C")" disabled />
            </div>
        </div>

    </div>

    <div class="d-flex flex-row justify-content-evenly align-items-center">
        <div class="card col-md-8">
            <div class="card-header">
                <h5 class="card-text text-center">
                    Produtos
                </h5>
            </div>
            <div class="card-body">
                <table class="table">
                    <thead>
                    <tr>
                        <th style="width: 30%">Nome</th>
                        <th class="text-center" style="width: 20%">Categoria</th>
                        <th class="text-center" style="width: 20%">Marca</th>
                        <th class="text-center" style="width: 10%">Quantidade</th>
                        <th class="text-end" style="width: 20%">Valor</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in _response.Itens)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td class="text-center">@item.ProductCategory</td>
                            <td class="text-center">@item.ProductBrand</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end text-success"><strong>@item.ProductPrice.ToString("C")</strong></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
}
@page "/detalhes-produto"

@if (_carregando)
{
    <Carregando Tipo="Carregando.ECarregandoTipo.Primary" EstaCarregando="_carregando" />
}
else if (_erroAoCarregarProduto)
{
    <Alerta
        Tipo="Alerta.TipoAlerta.Erro"
        Mensagem="Não foi possível carregar o produto."/>

    <BotaoTentarNovamente TentarNovamente="@(async () => await CarregaDadosProduto())" />
}
else
{
    <h4 class="fs-4 text-center my-4">Detalhes do Produto: @_product?.Name</h4>

    <div class="form-group row my-2">
        <label class="form-label col-md-3 my-auto text-end">Nome:</label>
        <div class="col-md-6">
            <input type="text" class="form-control" value="@_product?.Name" disabled />
        </div>
    </div>

    <div class="form-group row my-2">
        <label class="from-label col-md-3 my-auto text-end">Descrição</label>
        <div class="col-md-6">
            <textarea rows="5" class="form-control" value="@_product?.Description" disabled ></textarea>
        </div>
    </div>

    <div class="form-group row my-2">
        <label class="form-label col-md-3 my-auto text-end">Valor</label>
        <div class="col-md-6">
            <input type="text" class="form-control" value="@_product?.Price.ToString("C")" disabled />
        </div>
    </div>

    <div class="form-group row my-2">
        <label class="form-label col-md-3 my-auto text-end">URL imagem produto:</label>
        <div class="col-md-6">
            <input type="text" class="form-control" value="@_product?.ImageUrl" disabled />
        </div>
    </div>

    <div class="form-group row my-2">
        <label class="form-label col-md-3 my-auto text-end">Categoria:</label>
        <div class="col-md-6">
            <input type="text" class="form-control" value="@_product?.Category" disabled />
        </div>
    </div>

    <div class="form-group row my-2">
        <label class="form-label col-md-3 my-auto text-end my-auto">Marca:</label>
        <div class="col-md-6">
            <input type="text" class="form-control" value="@_product?.Brand" disabled />
        </div>
    </div>

    <div class="form-group row my-2">
        <label class="form-label col-md-3 my-auto text-end">Quantidade:</label>
        <div class="col-md-6">
            <input type="text" class="form-control" value="@_product?.Stock" disabled />
        </div>
    </div>

    <div class="form-group row my-2">
        <label class="form-label col-md-3 my-auto text-end">Está Ativo:</label>
        <div class="form-check col-md-2 ms-3">
            <input type="checkbox" class="form-check-input" checked="@_product?.IsActive" disabled />
        </div>
    </div>

    <div class="form-group row my-2">
        <label class="form-label col-md-3 my-auto text-end">Criado por:</label>
        <div class="col-md-6">
            <input type="text" class="form-control" value="@_product?.CreatedBy" disabled />
        </div>
        <div class="col-md-2">
            <input type="text" class="form-control" value="@_product?.CreatedOn.ToString("dd/MM/yyyy hh:mm:ss")" disabled />
        </div>
    </div>

    <div class="form-group row my-2">
        <label class="form-label col-md-3 my-auto text-end">Modificado por:</label>
        <div class="col-md-6">
            <input type="text" class="form-control" value="@_product?.ModifiedBy" disabled />
        </div>
        <div class="col-md-2">
            <input type="text" class="form-control" value="@_product?.ModifiedOn.ToString("dd/MM/yyyy hh:mm:ss")" disabled />
        </div>
    </div>

}
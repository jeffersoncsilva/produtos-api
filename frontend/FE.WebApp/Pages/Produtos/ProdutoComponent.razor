@using FE.ViewModels.Features.Product

<div class="card col-md-3 m-2">
    <div class="card-header">
        <h5 class="card-text">
            @Product?.Name
        </h5>
    </div>
    <div class="card-body">
        <h6>
            @Product?.Price.ToString("C")
        </h6>
    </div>
    <AuthorizeView Roles="Admin">
        <div class="card-footer">
            <div class="d-flex flex-row align-content-start flex-wrap">

                <button type="button" class="btn btn-primary btn-sm" @onclick=@(() => OnSelected?.Invoke(Product))>Editar</button>
                <button type="button" class="btn btn-secondary btn-sm" @onclick="@(() => OnVendaSelected?.Invoke(Product))">Vender</button>

            </div>
        </div>
    </AuthorizeView>
</div>




@code {
    [Parameter] public ProductSimpleViewModel? Product { get; set; }

    [Parameter] public Action<ProductSimpleViewModel?>? OnSelected { get; set; }

    [Parameter] public Action<ProductSimpleViewModel?>? OnVendaSelected { get; set; }


}

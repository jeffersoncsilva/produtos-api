@page "/login"
@using Blazored.LocalStorage
@using FE.Application.Features.Login.RealizarLoginCommand
@layout LoginLayout
@inject IMediator Mediator
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthProvider

@if (_editContext is null)
{

}
else
{
    <section class="vh-100 gradient-custom">
        <div class="container py-5 h-100">
            <div class="row d-flex justify-content-center align-items-center h-100">
                <div class="col-12 col-md-8 col-lg-6 col-xl-5">
                    <div class="card bg-dark text-white" style="border-radius: 1rem;">
                        <div class="card-body p-5 text-center">

                            <div class="mb-md-5 mt-md-4 pb-5">

                                <h2 class="fw-bold mb-2 text-uppercase">Login</h2>
                                <p class="text-white-50 mb-5">Por favor, insira seu email e senha para realizar o login.</p>
                                <EditForm EditContext="_editContext" OnValidSubmit="RealizaLogin">
                                    <div data-mdb-input-init class="form-outline form-white mb-4">
                                        <label class="form-label" for="typeEmailX">Email</label>
                                        <InputText type="email" id="typeEmail" class="form-control form-control-lg" @bind-Value="_login.Email"/>
                                        <ValidationMessage For="() => _login.Email"/>
                                    </div>

                                    <div data-mdb-input-init class="form-outline form-white mb-4">
                                        <label class="form-label" for="typePasswordX">Senha</label>
                                        <InputText type="password" id="typePasswordX" class="form-control form-control-ls" @bind-Value="_login.Senha" />
                                        <ValidationMessage For="() => _login.Senha" />
                                    </div>

                                    <p class="small mb-5 pb-lg-2"><a class="text-white-50" href="/esqueceu-senha">Esqueceu a Senha?</a></p>

                                    <button data-mdb-button-init data-mdb-ripple-init class="btn btn-outline-light btn-lg px-5" type="submit">Entrar</button>
                                </EditForm>
                            </div>

                            <div>
                                <p class="mb-0">
                                    Não tem uma conta ainda? <a href="/nova-conta" class="text-white-50 fw-bold">Criar conta.</a>
                                </p>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}


@code {
    private LoginRequest? _login;
    private EditContext? _editContext;
    private ValidationMessageStore? _messageStore;

    protected override void OnInitialized()
    {
        _login = new();
        _editContext = new(_login);
        _editContext.OnValidationRequested += HandleValidationRequested;
        _messageStore = new(_editContext);
        base.OnInitialized();
    }

    private void HandleValidationRequested(object? sender, ValidationRequestedEventArgs args)
    {
        _messageStore?.Clear();

        if(string.IsNullOrWhiteSpace(_login?.Email))
            _messageStore?.Add(() => _login.Email, "Preencha o campo com o login.");

        if (string.IsNullOrWhiteSpace(_login?.Senha))
            _messageStore?.Add(() => _login.Senha, "Senha é obrigatória.");
    }


    private async Task RealizaLogin()
    {
        var resultado = await Mediator.Send(_login!);
        if (resultado is not null && resultado.Success)
        {
            ((ApiAuthenticationStateProvider)AuthProvider).MarkUserAsAuthenticated(resultado.AccessToken!);
            NavManager.NavigateTo("vendas");
        }
    }
}
